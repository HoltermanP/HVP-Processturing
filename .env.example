# Environment variables — stel deze in Vercel in (Project → Settings → Environment Variables).
# Voor lokaal draaien met `vercel dev` kun je ze ook in een .env-bestand zetten (niet committen).

# Neon Postgres connectionstring (Neon dashboard → Connection string → "Pooled connection").
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Anthropic API-sleutel voor de rapportagegenerator.
ANTHROPIC_API_KEY=sk-ant-...
