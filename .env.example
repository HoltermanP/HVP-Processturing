# Environment variables — stel deze in Vercel in (Project → Settings → Environment Variables).
# Voor lokaal draaien met `vercel dev` kun je ze ook in een .env-bestand zetten (niet committen).

# Neon Postgres connectionstring (Neon dashboard → Connection string → "Pooled connection").
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Anthropic API-sleutel voor de rapportagegenerator.
ANTHROPIC_API_KEY=sk-ant-...

# Clerk — authenticatie. Maak een applicatie op https://dashboard.clerk.com en
# kopieer de Publishable Key. Deze (pk_...) is publiek en wordt via /api/config
# aan de browser doorgegeven om het login-scherm te tonen. Zonder deze sleutel
# draait de app zonder login (devmodus, volledige rechten).
CLERK_PUBLISHABLE_KEY=pk_test_...
# De Secret Key (sk_...) is nu nog niet nodig (rechten worden in de UI
# afgedwongen), maar staat klaar voor latere serverside-handhaving.
# CLERK_SECRET_KEY=sk_test_...
